# ─── Kronos AIOps Frontend — Environment Variables ───────────────────────────
#
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit real URLs or secrets.
#
# After `terraform apply` run:
#   terraform output http_api_url   → VITE_API_BASE_URL
#   terraform output websocket_url  → VITE_WS_URL

# Base URL for the HTTP REST API (no trailing slash)
# e.g. https://tozg3pwytc.execute-api.us-east-1.amazonaws.com
VITE_API_BASE_URL=https://YOUR_HTTP_API_ID.execute-api.us-east-1.amazonaws.com

# WebSocket URL (wss://)
# e.g. wss://r0o037d2gc.execute-api.us-east-1.amazonaws.com/prod
VITE_WS_URL=wss://YOUR_WS_API_ID.execute-api.us-east-1.amazonaws.com/prod

# Set to "true" to use local mock data instead of hitting AWS
# Useful for pure UI development without AWS credentials
VITE_USE_MOCK=false
